FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Instructions:
# 1. Copy this file → rename to .env
# 2. Fill in your real Firebase values from Firebase Console
# 3. Run: powershell -ExecutionPolicy Bypass -File setup-env.ps1
# 4. This generates assets/js/firebase-config.js locally
# NOTE: .env and firebase-config.js are gitignored — never committed
